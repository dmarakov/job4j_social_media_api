<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1772802210027" author="Dmitrii">
        <createTable tableName="post_files">
            <column name="post_id" type="bigint" autoIncrement="true">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_post_files_post"
                        referencedTableName="posts"
                        referencedColumnNames="id"/>
            </column>
            <column name="file_id" type="bigint">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_post_files_file"
                        referencedTableName="files"
                        referencedColumnNames="id"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="post_files"
                columnNames="post_id, file_id"
                constraintName="uk_post_files_post_id_file_id"/>
        <rollback>
            <dropTable tableName="post_files"/>
        </rollback>
    </changeSet>

</databaseChangeLog>    