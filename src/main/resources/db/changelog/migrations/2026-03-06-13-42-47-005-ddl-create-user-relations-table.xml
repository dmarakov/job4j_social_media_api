<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet id="1772804604284" author="Dmitrii">
        <createTable tableName="user_relations">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="from_user_id" type="bigint">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_user_relations_from_user"
                        referencedTableName="users"
                        referencedColumnNames="id"
                />
            </column>
            <column name="to_user_id" type="bigint">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_user_relations_to_user"
                        referencedTableName="users"
                        referencedColumnNames="id"
                />
            </column>
            <column name="subscribed" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="friend" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="user_relations"
                             columnNames="from_user_id, to_user_id"
                             constraintName="uk_user_relations_from_to"/>
        <rollback>
            <dropTable tableName="user_relations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>    